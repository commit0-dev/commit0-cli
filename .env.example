# ──────────────────────────────────────────────────────────────
# General
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# Embedding provider — choose ONE: "gemini", "voyage", or "ollama"
# ──────────────────────────────────────────────────────────────
EMBED_PROVIDER=gemini

# ──────────────────────────────────────────────────────────────
# Option 1: Gemini (cloud) — default
# Get a key at https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=gemini-embedding-2-preview
GEMINI_EXPLAIN_MODEL=gemini-2.5-flash
GEMINI_EMBED_DIM=3072
GEMINI_BATCH_SIZE=100

# ──────────────────────────────────────────────────────────────
# Option 2: Voyage AI (cloud)
# Set EMBED_PROVIDER=voyage to use Voyage for embeddings.
# LLM features still use Gemini (GEMINI_API_KEY required).
# ──────────────────────────────────────────────────────────────
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-code-3
# VOYAGE_EMBED_DIM=1024
# VOYAGE_BATCH_SIZE=128

# ──────────────────────────────────────────────────────────────
# Option 3: Ollama (fully local — zero cost, air-gapped)
# Set EMBED_PROVIDER=ollama. No cloud API keys needed.
# Requires: ollama pull nomic-embed-text
# ──────────────────────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_EMBED_DIM=768

# ──────────────────────────────────────────────────────────────
# SurrealDB connection
# ──────────────────────────────────────────────────────────────
SURREAL_URL=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NAMESPACE=commit0
SURREAL_DATABASE=codebase

# ──────────────────────────────────────────────────────────────
# HTTP server
# ──────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_CORS_ORIGINS=*
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=120

# ──────────────────────────────────────────────────────────────
# Indexing workers
# ──────────────────────────────────────────────────────────────
# INDEX_WORKERS_PARSE defaults to GOMAXPROCS when unset
INDEX_WORKERS_PARSE=
INDEX_WORKERS_EMBED=4
INDEX_WORKERS_STORE=4
INDEX_MAX_FILE_KB=10000
INDEX_BATCH_SIZE=100

# ──────────────────────────────────────────────────────────────
# Query tuning
# ──────────────────────────────────────────────────────────────
QUERY_DEFAULT_TOP_K=10
QUERY_MIN_SCORE=0.5
QUERY_RRF_K=60
