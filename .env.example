# Gemini API — required
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini models (optional — defaults shown)
GEMINI_EMBED_MODEL=gemini-embedding-2-preview
GEMINI_EXPLAIN_MODEL=gemini-2.0-flash
GEMINI_EMBED_DIM=3072
GEMINI_BATCH_SIZE=100

# SurrealDB connection (optional — defaults shown)
SURREAL_URL=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NAMESPACE=commit0
SURREAL_DATABASE=codebase

# HTTP server (optional — defaults shown)
SERVER_PORT=8080
SERVER_CORS_ORIGINS=*
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=120

# Indexing workers (optional — defaults shown)
# INDEX_WORKERS_PARSE defaults to GOMAXPROCS when unset
INDEX_WORKERS_PARSE=
INDEX_WORKERS_EMBED=4
INDEX_WORKERS_STORE=8
INDEX_MAX_FILE_KB=10000
INDEX_BATCH_SIZE=100

# Query tuning (optional — defaults shown)
QUERY_DEFAULT_TOP_K=10
QUERY_MIN_SCORE=0.5
QUERY_RRF_K=60
