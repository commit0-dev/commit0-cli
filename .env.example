# ──────────────────────────────────────────────────────────────
# General
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# Embedding — shared across all providers
# ──────────────────────────────────────────────────────────────
EMBED_PROVIDER=gemini          # "gemini", "voyage", or "ollama"
EMBED_DIM=1024                 # Normalized HNSW dimension (all providers output at this dim)
BATCH_SIZE=100                 # Embedding batch size

# ──────────────────────────────────────────────────────────────
# Gemini (cloud) — default embedding + LLM provider
# Get a key at https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_EMBED_MODEL=gemini-embedding-2-preview
GEMINI_EXPLAIN_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────
# Voyage AI (cloud) — set EMBED_PROVIDER=voyage
# ──────────────────────────────────────────────────────────────
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-code-3

# ──────────────────────────────────────────────────────────────
# Ollama (fully local) — set EMBED_PROVIDER=ollama
# Requires: ollama pull qwen3-embedding:4b
# ──────────────────────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_EMBED_MODEL=qwen3-embedding:4b

# ──────────────────────────────────────────────────────────────
# LLM provider (separate from embeddings)
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini            # "gemini", "openrouter", or "ollama"
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# ──────────────────────────────────────────────────────────────
# SurrealDB connection
# ──────────────────────────────────────────────────────────────
SURREAL_URL=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NAMESPACE=commit0
SURREAL_DATABASE=codebase

# ──────────────────────────────────────────────────────────────
# HTTP server
# ──────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_CORS_ORIGINS=*

# ──────────────────────────────────────────────────────────────
# Indexing workers
# ──────────────────────────────────────────────────────────────
INDEX_WORKERS_EMBED=4
INDEX_WORKERS_STORE=4
INDEX_MAX_FILE_KB=10000

# ──────────────────────────────────────────────────────────────
# Query tuning
# ──────────────────────────────────────────────────────────────
QUERY_DEFAULT_TOP_K=10
QUERY_MIN_SCORE=0.5
QUERY_RRF_K=60
