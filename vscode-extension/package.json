{
  "name": "commit0",
  "displayName": "commit0",
  "description": "Graph-based code intelligence — callers, callees, trace, blast radius",
  "version": "0.1.0",
  "publisher": "commit0-dev",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commit0.query",
        "title": "commit0: Search Code",
        "icon": "$(search)"
      },
      {
        "command": "commit0.traceSymbol",
        "title": "commit0: Trace Call Chain",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "commit0.blastSymbol",
        "title": "commit0: Blast Radius",
        "icon": "$(pulse)"
      },
      {
        "command": "commit0.indexProject",
        "title": "commit0: Index Project",
        "icon": "$(sync)"
      },
      {
        "command": "commit0.indexProjectDirect",
        "title": "commit0: Index Project (Direct)",
        "icon": "$(play)"
      },
      {
        "command": "commit0.addProject",
        "title": "commit0: Add Project",
        "icon": "$(add)"
      },
      {
        "command": "commit0.removeProject",
        "title": "commit0: Remove Project",
        "icon": "$(trash)"
      },
      {
        "command": "commit0.refreshProjects",
        "title": "commit0: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "commit0.revealInFinder",
        "title": "commit0: Reveal in Finder"
      },
      {
        "command": "commit0.showHelp",
        "title": "commit0: Getting Started"
      },
      {
        "command": "commit0.openChat",
        "title": "commit0: Open Chat",
        "icon": "$(comment-discussion)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commit0",
          "title": "commit0",
          "icon": "$(graph)"
        }
      ],
      "panel": [
        {
          "id": "commit0-chat",
          "title": "commit0 Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "commit0": [
        {
          "id": "commit0.projects",
          "name": "Projects"
        }
      ],
      "commit0-chat": [
        {
          "id": "commit0.chatView",
          "type": "webview",
          "name": "Chat"
        }
      ],
      "explorer": [
        {
          "id": "commit0.graphLinks",
          "name": "Graph Links"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "commit0.projects",
        "contents": "No projects found.\n[Add Project](command:commit0.addProject)\nMake sure `commit0 serve` is running.",
        "when": "true"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "commit0.refreshProjects",
          "when": "view == commit0.projects",
          "group": "navigation"
        },
        {
          "command": "commit0.addProject",
          "when": "view == commit0.projects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "commit0.indexProjectDirect",
          "when": "viewItem == project-unindexed",
          "group": "inline"
        },
        {
          "command": "commit0.indexProjectDirect",
          "when": "viewItem == project-indexed",
          "group": "1_actions@1"
        },
        {
          "command": "commit0.query",
          "when": "viewItem == project-indexed",
          "group": "1_actions@2"
        },
        {
          "command": "commit0.removeProject",
          "when": "viewItem == project-indexed || viewItem == project-unindexed",
          "group": "2_danger@1"
        }
      ],
      "editor/context": [
        {
          "command": "commit0.traceSymbol",
          "group": "commit0@1"
        },
        {
          "command": "commit0.blastSymbol",
          "group": "commit0@2"
        }
      ]
    },
    "configuration": {
      "title": "commit0",
      "properties": {
        "commit0.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the commit0 HTTP API server"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8"
  }
}
